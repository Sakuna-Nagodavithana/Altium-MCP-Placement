<Window x:Class="EasyEDA_Loader.McpControlWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Altium MCP Control Panel"
    Height="620"
    Width="760"
    MinHeight="480"
    MinWidth="680"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="False"
    Loaded="Window_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Altium MCP Control Panel" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Project data exports automatically for Cursor. Open this panel once with your project open."
                       Margin="0,6,0,0" TextWrapping="Wrap" Opacity="0.85"/>
        </StackPanel>

        <Border Grid.Row="1" Padding="12" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Server status" FontWeight="SemiBold"/>
                    <TextBlock x:Name="serverStatusText" Text="Checking..." Margin="0,6,0,0"/>
                    <TextBlock x:Name="exportStatusText" Text="" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="startServerButton" Content="Restart Server" Width="110" Height="28" Margin="0,0,8,0" Click="StartServerButton_Click"/>
                    <Button x:Name="stopServerButton" Content="Stop Server" Width="110" Height="28" Click="StopServerButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Padding="12" BorderBrush="#444" BorderThickness="1" CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Automatic export" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Exports schematic, connectivity, and PCB validation data into connectivity.json."
                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Export file" VerticalAlignment="Center"/>
                        <TextBlock x:Name="exportPathText" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="MCP URL" Margin="0,8,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="serverUrlText" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="API key" Margin="0,8,0,0" VerticalAlignment="Top"/>
                        <TextBox x:Name="apiKeyText" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" IsReadOnly="True" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Python" Margin="0,8,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="pythonPathText" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Server script" Margin="0,8,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="serverScriptText" Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </Grid>

                    <TextBlock x:Name="summaryText" Text="" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="exportButton" Content="Export Now" Width="110" Height="28" Margin="0,0,8,0" Click="ExportButton_Click"/>
                        <Button x:Name="openFolderButton" Content="Open AltiumEE Folder" Width="150" Height="28" Margin="0,0,8,0" Click="OpenFolderButton_Click"/>
                        <Button x:Name="openSettingsButton" Content="Open Settings" Width="110" Height="28" Click="OpenSettingsButton_Click"/>
                    </StackPanel>

                    <TextBlock Text="IC cluster placement" FontWeight="SemiBold" Margin="0,18,0,8"/>
                    <TextBlock Text="Placement uses the built-in C# planner (no Python). Python is only required for the MCP server used by Cursor."
                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Anchor IC" VerticalAlignment="Center"/>
                        <TextBox x:Name="anchorIcText" Grid.Column="1" Text="IC1" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="2" Text="Spacing (mils)" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="spacingMilsText" Grid.Column="3" Text="80"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Max radius" VerticalAlignment="Center"/>
                        <TextBox x:Name="maxRadiusText" Grid.Column="1" Text="900" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="2" Text="Sch distance" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="maxSchDistanceText" Grid.Column="3" Text="2500"/>
                    </Grid>

                    <Button x:Name="clusterAllIcPartsButton" Content="Place Support Passives (All ICs)" Width="260" Height="32" Margin="0,0,0,8" Click="ClusterAllIcPartsButton_Click"/>
                    <Button x:Name="clusterIcPartsButton" Content="Place Passives (One IC)" Width="260" Height="32" Margin="0,0,0,10" Click="ClusterIcPartsButton_Click"/>

                    <TextBlock x:Name="placementStatusText" Text="" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="generatePlanButton" Content="Generate Plan Only" Width="140" Height="28" Margin="0,0,8,0" Click="GeneratePlanButton_Click"/>
                        <Button x:Name="applyPlanButton" Content="Apply Plan Only" Width="130" Height="28" Margin="0,0,8,0" Click="ApplyPlanButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="hintText" VerticalAlignment="Center" Margin="0,0,12,0" Opacity="0.75" Text="Place Support Passives handles every IC/U in one pass. Undo with Ctrl+Z."/>
            <Button Content="Close" Width="80" Height="28" IsCancel="True" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
