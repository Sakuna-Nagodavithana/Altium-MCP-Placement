# Copy this file to `.env` and fill in the values.
# NEVER commit `.env` or share your API key.

# Required for online/ngrok mode
MCP_API_KEY=replace-with-output-from-generate-api-key.ps1

# Local server bind address (keep 127.0.0.1; ngrok connects to localhost)
MCP_HOST=127.0.0.1
MCP_PORT=8787

# After ngrok starts, paste the HTTPS URL here (no trailing slash)
# Example: https://abc123.ngrok-free.app
MCP_PUBLIC_URL=https://YOUR-SUBDOMAIN.ngrok-free.app

# Where Altium writes the export
ALTIUM_CONNECTIVITY_FILE=%USERPROFILE%\Documents\AltiumEE\connectivity.json

# stdio = local Cursor only
# streamable-http = online mode used by start-online.ps1
MCP_TRANSPORT=stdio
